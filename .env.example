# Whisper model size: tiny | base | small | medium
# small is recommended: good accuracy, runs on CPU in reasonable time
WHISPER_MODEL=small

# Set to true to save the recorded audio as a .wav file alongside results
# Useful for testing and debugging. Keep false for normal use (privacy).
SAVE_AUDIO=false

# Set to true to save a plain-text .txt transcript alongside the results JSON
# Useful for reviewing / labelling. Keep false for normal use.
SAVE_TRANSCRIPT_TXT=false

# Set to false for privacy mode: transcribed text is used for classification
# but is NOT written anywhere — only timestamps, labels, and confidence are saved.
# The plain-text transcript is also suppressed when this is false.
SAVE_TEXT_IN_JSON=true
